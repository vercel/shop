    "@shopify/api-codegen-preset": "2.0.0",
    "@shopify/storefront-api-client": "1.0.10",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "7.0.0-beta.183",
    "babel-plugin-react-compiler": "1.0.0",
    "better-auth": "1.6.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.21.0",
    "nanoid": "5.1.11",
    "next": "16.3.0-canary.61",
    "next-intl": "4.13.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "postcss": "8.5.15",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "use-stick-to-bottom": "1.1.6",
    "zod": "4.4.3"
  }
