{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "graphql-codegen && next build",
    "codegen": "graphql-codegen",
    "codegen:watch": "graphql-codegen --watch",
    "dev": "graphql-codegen || true && next dev",
    "dev:portless": "graphql-codegen || true && portless shop next dev",
    "format": "oxfmt",
    "lint": "oxlint . && oxfmt --check",
    "start": "next start"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@graphql-codegen/cli": "7.1.3",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@shopify/api-codegen-preset": "2.0.1",
    "@shopify/storefront-api-client": "1.0.10",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "7.0.9",
    "babel-plugin-react-compiler": "1.0.0",
    "better-auth": "1.6.22",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "eve": "0.18.2",
    "lucide-react": "1.21.0",
    "nanoid": "5.1.16",
    "next": "16.3.0-canary.72",
    "next-intl": "4.13.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=24"
  }
