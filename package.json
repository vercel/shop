{
  "dependencies": {
    "turbo": "2.9.6"
  },
  "name": "@vercel/shop",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "turbo run format",
